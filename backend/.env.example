PORT=5000

# MongoDB Connection (Choose one):
# Option A: Local MongoDB (Default)
MONGO_URI=mongodb://127.0.0.1:27017/thumbnail_ai
# Option B: MongoDB Atlas (Cloud)
# MONGO_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/thumbnail_ai?retryWrites=true&w=majority

JWT_SECRET=your_jwt_secret_key_here

# Hugging Face Inference API Token (Used as fallback if Pollinations AI fails)
HUGGING_FACE_TOKEN=hf_your_hugging_face_token_here
